        Queue<Integer> q=new LinkedList<>();
        color[s2]=1;
        q.add(s2);
        while (!q.isEmpty()) {
            int u=q.remove();
            for(int i=0;i<a[u].size();i++){
                int x=a[u].get(i);
                if(color[x]==0){
                    color[x]=1;
                    if(x!=s1&&parent[x]==0){
                        parent[x]=u;
                        distance[x]=distance[parent[x]]+1;
                    }
                    q.add(x);
                }
            }
