    public static void mergesort(long[] a,int l,int r){
        if(l<r){
            int m=l+(r-l)/2;
            mergesort(a, l, m);
            mergesort(a, m+1, r);
            merge(a,l,r,m);
        }
    }
    public static int find(long[] a, int l, int r, long val) {
        int ans=-1;
        while (l<=r) {
            int m=l+(r-l)/2;
            if ((long)a[m]>val){
                ans = m;
                r=m-1;
            }
            else{
                l=m+1;
            }
        }
        return ans;
    }
    public static void merge(long[] a,int l,int r,int m){
        int n1=m-l+1;
        int n2=r-m;
        long[] L=new long[n1];
        long[] R=new long[n2];
        for(int i=0;i<n1;i++){
            L[i]=a[l+i];
        }
        for(int i=0;i<n2;i++){
            R[i]=a[m+1+i];
        }
        for (int j=m+1;j<=r;j++) {
            long val=a[j]*a[j];
            int idx= find(a, l, m, val);
            if (idx!=-1) {
                y+=(m-idx+1);
            }
        }
        int i=0,j=0,q=l;
        while(i<n1&&j<n2){
            if(L[i]<=R[j]){
                a[q++]=L[i++];
            }
            else{
                a[q++]=R[j++];
            }
        }
        while(i<n1){
            a[q++]=L[i++];
        }
        while(j<n2){
            a[q++]=R[j++];
        }
    }
}






