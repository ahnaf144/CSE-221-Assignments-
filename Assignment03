import java.io.BufferedReader;
import java.util.StringTokenizer;
import java.io.InputStreamReader;
import java.io.PrintWriter;
public class g {
    public static long[] in;
    public static long[] pr;
    public static long[] po;
    public static int prx=0,pox=0;
    public static void main(String[] args) throws Exception {
        BufferedReader br=new BufferedReader(new InputStreamReader(System.in));
        StringTokenizer st=new StringTokenizer(br.readLine());
        PrintWriter pw=new PrintWriter(System.out);
        int n=Integer.parseInt(st.nextToken());
        in=new long[n];
        pr=new long[n];
        po=new long[n];
        st=new StringTokenizer(br.readLine());
        for(int i=0;i<n;i++){
            in[i]=Long.parseLong(st.nextToken());
        }
        st=new StringTokenizer(br.readLine());
        for(int i=0;i<n;i++){
            pr[i]=Long.parseLong(st.nextToken());
        }
        build(0,n-1);
        for(int i=0;i<n;i++){
            pw.print(po[i]+" ");
        }
        pw.flush();
        pw.close();
    }
    public static void build(int l,int r){
        if(l<=r){
            long root=pr[prx++];
            int x=l;
            while(x<=r&&in[x]!=root){
                x++;
            }
            build(l, x-1);
            build(x+1, r);
            po[pox++]=root;
        }
    }
}




import java.io.BufferedReader;
import java.util.StringTokenizer;
import java.io.InputStreamReader;
import java.io.PrintWriter;
public class h {
    public static int[] in, po, pre;
    public static int prx=0;
    public static void main(String[] args) throws Exception {
        BufferedReader br=new BufferedReader(new InputStreamReader(System.in));
        StringTokenizer st=new StringTokenizer(br.readLine());
        PrintWriter pw=new PrintWriter(System.out);
        int n=Integer.parseInt(st.nextToken());
        in=new int[n];
        po=new int[n];
        pre=new int[n];
        st=new StringTokenizer(br.readLine());
        for(int i=0;i<n;i++){
            in[i]=Integer.parseInt(st.nextToken());
        }
        st=new StringTokenizer(br.readLine());
        for(int i=0;i<n;i++){
            po[i]=Integer.parseInt(st.nextToken());
        }
        buildpre(0,n-1,0,n-1);
        for(int i=0;i<n;i++){
            pw.print(pre[i]+" ");
        }
        pw.println();
        pw.flush();
        pw.close();
    }
    public static void buildpre(int il,int ir,int pl,int pr){
        if(il>ir){
            return;
        }
        int root=po[pr];
        pre[prx++]=root;
        int x=il;
        while(in[x]!=root){
            x++;
        }
        int left=x-il;
        buildpre(il,x-1,pl,pl+left-1);
        buildpre(x+1,ir,pl+left,pr-1);
    }
}

