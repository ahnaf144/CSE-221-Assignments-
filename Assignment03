public class d {
    public static void main(String[] args) throws Exception{
        BufferedReader br=new BufferedReader(new InputStreamReader(System.in));
        StringTokenizer st=new StringTokenizer(br.readLine());
        PrintWriter pw=new PrintWriter(System.out);
        int t=Integer.parseInt(st.nextToken());
        long m=(long)Math.pow(10, 9)+7;
        while(t-->0){
            st=new StringTokenizer(br.readLine());
            long[] a=new long[4];
            for(int i=0;i<4;i++){
                a[i]=Long.parseLong(st.nextToken());
            }
            st=new StringTokenizer(br.readLine());
            long x=Long.parseLong(st.nextToken());
            long[] r={1,0,0,1};
            while(x>0){
                if(x%2!=0){
                    r=multiply(r,a,m);
                }
                a=multiply(a,a,m);
                x/=2;
            }
            for(int i=0;i<2;i++){
                pw.print(r[i]+" ");
            }
            pw.println();
            for(int i=2;i<4;i++){
                pw.print(r[i]+" ");
            }
            pw.println();
        }
        pw.flush();
        pw.close();
    }
    public static long[] multiply(long[] r,long[] a,long m){
        long[] t=new long[4];
        for(int i=0;i<4;i++){
            t[i]=r[i];
        }
        t[0]=((r[0]*a[0])+(r[1]*a[2]))%m;
        t[1]=((r[0]*a[1])+(r[1]*a[3]))%m;
        t[2]=((r[2]*a[0])+(r[3]*a[2]))%m;
        t[3]=((r[2]*a[1])+(r[3]*a[3]))%m;
        return t;
    }
}







