import java.io.*;
import java.util.*;
public class EParityEdges {
    public static void main(String[] args) throws Exception{
        BufferedReader br=new BufferedReader(new InputStreamReader(System.in));
        StringTokenizer st=new StringTokenizer(br.readLine());
        PrintWriter pw=new PrintWriter(System.out);
        int n=Integer.parseInt(st.nextToken());
        int m=Integer.parseInt(st.nextToken());
        int[] u=new int[m+1];
        int[] v=new int[m+1];
        int[] w=new int[m+1];
        st=new StringTokenizer(br.readLine());
        for(int i=1;i<=m;i++){
            u[i]=Integer.parseInt(st.nextToken());
        }
        st=new StringTokenizer(br.readLine());
        for(int i=1;i<=m;i++){
            v[i]=Integer.parseInt(st.nextToken());
        }
        st=new StringTokenizer(br.readLine());
        for(int i=1;i<=m;i++){
            w[i]=Integer.parseInt(st.nextToken());
        }
        ArrayList<int[]>[] g=new ArrayList[n+1];
        for(int i=1;i<=n;i++){
            g[i]=new ArrayList<>();
        }
        for(int i=1;i<=m;i++){
            g[u[i]].add(new int[]{v[i],w[i]});
        }
        int[][] dis=new int[n+1][2];
        for(int i=1;i<=n;i++){
            Arrays.fill(dis[i], Integer.MAX_VALUE);
        }
        dis[1][0]=0;
        dis[1][1]=0;
        PriorityQueue<int[]> q=new PriorityQueue<>((a,b)->Integer.compare(a[1], b[1]));
        q.add(new int[]{1,0,0});
        q.add(new int[]{1,0,1});
        while (!q.isEmpty()) {
            int[] e=q.remove();
            int node=e[0];
            int dist=e[1];
            int prevParity=e[2];
            if(dist>dis[node][prevParity]){
                continue;
            }
            for(int i=0;i<g[node].size();i++){
                int[] curr=g[node].get(i);
                int next=curr[0];
                int weight=curr[1];
                int parity=weight%2;
                if(parity==prevParity){
                    continue;
                }
                if(dist+weight<dis[next][parity]){
                    dis[next][parity]=dist+weight;
                    q.add(new int[]{next,dis[next][parity],parity});
                }
            }
        }
        if(Math.min(dis[n][0], dis[n][1])!=Integer.MAX_VALUE){
            pw.println(Math.min(dis[n][0], dis[n][1]));
        }
        else{
            pw.println("-1");
        }
        pw.flush();
        pw.close();
    }
    
}







import java.io.*;
import java.util.*;
public class FShortestPathRevisited {
    public static void main(String[] args) throws Exception{
        BufferedReader br=new BufferedReader(new InputStreamReader(System.in));
        StringTokenizer st=new StringTokenizer(br.readLine());
        PrintWriter pw=new PrintWriter(System.out);
        int n=Integer.parseInt(st.nextToken());
        int m=Integer.parseInt(st.nextToken());
        int s=Integer.parseInt(st.nextToken());
        int d=Integer.parseInt(st.nextToken());
        ArrayList<int[]>[] g=new ArrayList[n+1];
        for(int i=1;i<=n;i++){
            g[i]=new ArrayList<>();
        }
        for(int i=0;i<m;i++){
            st=new StringTokenizer(br.readLine());
            int u=Integer.parseInt(st.nextToken());
            int v=Integer.parseInt(st.nextToken());
            int w=Integer.parseInt(st.nextToken());
            g[u].add(new int[]{v,w});
            g[v].add(new int[]{u,w});
        }
        int[] dis1=new int[n+1];
        int[] dis2=new int[n+1];
        Arrays.fill(dis1, Integer.MAX_VALUE);
        Arrays.fill(dis2, Integer.MAX_VALUE);
        dis1[s]=0;
        PriorityQueue<int[]> q=new PriorityQueue<>((a,b)->Integer.compare(a[1], b[1]));
        q.add(new int[]{s,dis1[s]});
        while (!q.isEmpty()) {
            int[] e=q.remove();
            int node=e[0];
            int dist=e[1];
            if(dist>dis2[node]){
                continue;
            }
            for(int i=0;i<g[node].size();i++){
                int[] curr=g[node].get(i);
                int next=curr[0];
                int weight=curr[1];
                if(dist+weight<dis1[next]){
                    dis2[next]=dis1[next];
                    dis1[next]=dist+weight;
                    q.add(new int[]{next,dis1[next]});
                }
                else if((dist+weight<dis2[next])&&(dist+weight>dis1[next])){
                    dis2[next]=dist+weight;
                    q.add(new int[]{next,dis2[next]});
                }
            }
        }
        if(dis2[d]!=Integer.MAX_VALUE){
            pw.println(dis2[d]);
        }
        else{
            pw.println("-1");
        }
        pw.flush();
        pw.close();
    }
    
}


