public class BWhereToMeet {
    public static void main(String[] args) throws Exception{
        BufferedReader br=new BufferedReader(new InputStreamReader(System.in));
        StringTokenizer st=new StringTokenizer(br.readLine());
        PrintWriter pw=new PrintWriter(System.out);
        int n=Integer.parseInt(st.nextToken());
        int m=Integer.parseInt(st.nextToken());
        int s=Integer.parseInt(st.nextToken());
        int t=Integer.parseInt(st.nextToken());
        ArrayList<int[]>[] g=new ArrayList[n+1];
        for(int i=1;i<=n;i++){
            g[i]=new ArrayList<>();
        }
        for(int i=1;i<=m;i++){
            st=new StringTokenizer(br.readLine());
            int u=Integer.parseInt(st.nextToken());
            int v=Integer.parseInt(st.nextToken());
            int w=Integer.parseInt(st.nextToken());
            g[u].add(new int[]{v,w});
        }
        int[] distA=new int[n+1];
        int[] distB=new int[n+1];
        Arrays.fill(distA, Integer.MAX_VALUE);
        Arrays.fill(distB, Integer.MAX_VALUE);
        dijkstra(g,distA,s);
        dijkstra(g,distB,t);
        int ans=Integer.MAX_VALUE;
        int idx=0;
        for(int i=1;i<=n;i++){
            int time=Math.max(distA[i],distB[i]);
            if(time<ans){
                ans=time;
                idx=i;
            }
        }
        if(ans==Integer.MAX_VALUE){
            pw.println("-1");
        }
        else{
            pw.println(ans+" "+idx);
        }
        pw.flush();
        pw.close();
    }
    public static void dijkstra(ArrayList<int[]>[] g,int[] dist,int s){
        dist[s]=0;
        PriorityQueue<int[]> q=new PriorityQueue<>((a,b)->Integer.compare(a[1], b[1]));
        q.add(new int[]{s,dist[s]});
        while (!q.isEmpty()) {
            int[] e=q.remove();
            int node=e[0];
            int dis=e[1];
            if(dis>dist[node]){
                continue;
            }
            for(int i=0;i<g[node].size();i++){
                int[] curr=g[node].get(i);
                int next=curr[0];
                int weight=curr[1];
                if(dis+weight<dist[next]){
                    dist[next]=dis+weight;
                    q.add(new int[]{next,dist[next]});
                }
            }
        }
    }
    
}








