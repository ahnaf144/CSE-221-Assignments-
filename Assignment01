import java.util.Scanner;
public class t3 {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int T=sc.nextInt();
        for(int i=0;i<T;i++){
            sc.next();
            double a=sc.nextDouble();
            String m=sc.next();
            double b=sc.nextDouble();
            double result=0;
            if(m.equals("+")){
                result=a+b;
            }
            if(m.equals("-")){
                result=a-b;
            }
            if(m.equals("*")){
                result=a*b;
            }
            if(m.equals("/")){
                result=a/b;
            }
            System.out.println(result);
        }
    }
}




