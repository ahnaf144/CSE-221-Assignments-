import java.util.Scanner;
public class a5 {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int a=sc.nextInt();
        int[] arr=new int[a];
        int arr2[]=new int[1000000];
        int c=0;
        for(int i=0;i<a;i++){
            arr[i]=sc.nextInt();
        }
        boolean sorted=true;
        boolean again=true;
        while(again){
            again=false;
            for(int i=0;i<a-2;i++){
                if(arr[i+2]<arr[i]){
                    int temp=arr[i];
                    arr[i]=arr[i+2];
                    arr[i+2]=temp;
                    arr2[c++]=i+1;
                    again=true;
                }
            }
        }
        for(int i=0;i<a-1;i++){
            for(int j=i+1;j<a;j++){
                if(arr[j]<arr[i]){
                    sorted=false;
                    break;
                }
            }
        }
        if(sorted){
            System.out.println("YES");
            System.out.println(c);
            for(int i=0;i<c;i++){
                System.out.println(arr2[i]+" "+(arr2[i]+2));
            }
        }
        else{
            System.out.println("NO");
        }
        sc.close();
    }
