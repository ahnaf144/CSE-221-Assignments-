import java.util.Scanner;
public class t7 {
    public static boolean first(int a, int b, int c, int d){
        if(b>d){
            return true;
        }
        if(b<d){
            return false;
        }
        return a<c;
    }
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        for(int i=0;i<n;i++){
            int[] id=new int[sc.nextInt()];
            int[] marks=new int[id.length];
            for(int j=0;j<id.length;j++){
                id[j]=sc.nextInt();
            }
            for(int j=0;j<marks.length;j++){
                marks[j]=sc.nextInt();
            }
            int[] id2=new int[id.length];
            int[] marks2=new int[id.length];
            int[] pos=new int[id.length];
            for(int j=0;j<id.length;j++){
                id2[j]=id[j];
                marks2[j]=marks[j];
                pos[j]=j;
            }
            for(int k=0;k<id.length-1;k++){
                for(int j=k+1;j<id.length;j++){
                    if(!first(id2[k], marks2[k], id2[j], marks2[j])){
                        int temp=id2[k];
                        id2[k]=id2[j];
                        id2[j]=temp;
                        temp=marks2[k];
                        marks2[k]=marks2[j];
                        marks2[j]=temp;
                        temp=pos[k];
                        pos[k]=pos[j];
                        pos[j]=temp;
                    }
                }
            }
            int[] put=new int[id.length];
            for(int k=0;k<id.length;k++){
                put[pos[k]]=k;
            }
            boolean[] isDone=new boolean[id.length];
            int c=0;
            for(int k=0;k<id.length;k++){
                if(isDone[k]||put[k]==k){
                    continue;
                }
                int d=0;
                int e=k;
                while(!isDone[e]){
                    isDone[e]=true;
                    e=put[e];
                    d++;
                }
                if(d>1){
                    c+=d-1;
                }
            }
            System.out.println("Minimum swaps: "+c);
            for(int l=0;l<id.length;l++){
                System.out.println("ID: "+id2[l]+" Mark: "+marks2[l]);
            }
        }
    }
}




