import java.util.Scanner;
public class t8 {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        String[] name= new String[n];
        String[] dest=new String[n];
        String[] time= new String[n];
        int[] idx=new int[n];
        int count=0;
        for(int i=0;i<n;i++){
            name[i]=sc.next();
            sc.next();
            sc.next();
            sc.next();
            dest[i]=sc.next();
            sc.next();
            time[i]=sc.next();
            idx[i]=count++;
        }
        for(int i=0;i<n-1;i++){
            for(int j=i+1;j<n;j++){
                int a=Math.min(name[i].length(), name[j].length());
                boolean swap=false;
                boolean same=true;
                for(int k=0;k<a;k++){
                    if(name[i].charAt(k)!=name[j].charAt(k)){
                        same=false;
                    }
                    if(name[i].charAt(k)<='Z'&&name[j].charAt(k)<='Z'){
                        if(name[j].charAt(k)<name[i].charAt(k)){
                            swap=true;
                        }
                    }
                    else if(name[i].charAt(k)<='Z'&&name[j].charAt(k)>='a'){
                        swap=true;
                    }
                    else if(name[i].charAt(k)>='a'&&name[j].charAt(k)>='a'){
                        if(name[j].charAt(k)<name[i].charAt(k)){
                            swap=true;
                        }
                    }
                    if(swap){
                        String temp=name[i];
                        name[i]=name[j];
                        name[j]=temp;
                        temp=dest[i];
                        dest[i]=dest[j];
                        dest[j]=temp;
                        temp=time[i];
                        time[i]=time[j];
                        time[j]=temp;
                        int temp2=idx[i];
                        idx[i]=idx[j];
                        idx[j]=temp2;
                        break;
                    }
                    if(!swap&&name[i].charAt(k)!=name[j].charAt(k)){
                        break;
                    }
                }
                if(!swap){ 
                    if(name[i].length()==name[j].length()){
                        if(same){
                            int hi=(time[i].charAt(0)-'0')*10+(time[i].charAt(1)-'0');
                            int mi=(time[i].charAt(3)-'0')*10+(time[i].charAt(4)-'0');
                            int hj=(time[j].charAt(0)-'0')*10+(time[j].charAt(1)-'0');
                            int mj=(time[j].charAt(3)-'0')*10+(time[j].charAt(4)-'0');
                            if(hj>hi || (hj==hi && mj>mi)){
                                String temp=name[i];
                                name[i]=name[j];
                                name[j]=temp;
                                temp=dest[i];
                                dest[i]=dest[j];
                                dest[j]=temp;
                                temp=time[i];
                                time[i]=time[j];
                                time[j]=temp;
                                int temp2=idx[i];
                                idx[i]=idx[j];
                                idx[j]=temp2;
                            }
                            else if(hj==hi&&mj==mi){
                                if(idx[j]<idx[i]){
                                    String temp=name[i];
                                    name[i]=name[j];
                                    name[j]=temp;
                                    temp=dest[i];
                                    dest[i]=dest[j];
                                    dest[j]=temp;
                                    temp=time[i];
                                    time[i]=time[j];
                                    time[j]=temp;
                                    int temp2=idx[i];
                                    idx[i]=idx[j];
                                    idx[j]=temp2;
                                }
                            }
                        }
                    }
                    else{
                        if(same){
                            if(name[j].length()<name[i].length()){
                                String temp=name[i];
                                name[i]=name[j];
                                name[j]=temp;
                                temp=dest[i];
                                dest[i]=dest[j];
                                dest[j]=temp;
                                temp=time[i];
                                time[i]=time[j];
                                time[j]=temp;
                                int temp2=idx[i];
                                idx[i]=idx[j];
                                idx[j]=temp2;
                                swap=true;
                            }
                        }
                    }
                }
            }
        }
        for(int i=0;i<n;i++){
            System.out.println(name[i]+" will depart for "+dest[i]+" at "+time[i]);
        }
        sc.close();
    }
}
